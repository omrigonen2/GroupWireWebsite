---
const appUrl = 'https://bo.groupwire.cloud';
type FooterColumn = [string, [string, string][]];
const columns: FooterColumn[] = [
  ['Product', [['Overview', '/product'], ['Features', '/features'], ['Pricing', '/pricing'], ['Integrations', '/integrations'], ['Mobile PWA', '/features/mobile-pwa']]],
  ['Solutions', [['Community managers', '/solutions/community-managers'], ['Small teams', '/solutions/teams'], ['Agencies', '/solutions/agencies']]],
  ['Developers', [['API and webhooks', '/developers'], ['Documentation', `${appUrl}/api/docs`], ['Security', '/security'], ['Releases', '/releases']]],
  ['Company', [['Contact', '/contact'], ['Book a demo', '/demo'], ['Resources', '/resources'], ['FAQ', '/faq']]],
  ['Legal', [['Terms', '/legal/terms'], ['Privacy', '/legal/privacy'], ['Cookies', '/legal/cookies'], ['Data processing', '/legal/data-processing'], ['Subprocessors', '/legal/subprocessors'], ['Acceptable use', '/legal/acceptable-use']]],
];
---
<footer class="site-footer">
  <div class="footer-main">
    <div class="footer-intro">
      <a class="brand brand-footer" href="/" aria-label="GroupWire home">
        <img class="brand-icon" src="/groupwire-icon.svg" alt="" width="38" height="38" />
        <span>GroupWire</span>
      </a>
      <p>AI-assisted WhatsApp publishing for teams, communities, and agencies that need to create, schedule, publish, and track content from one place.</p>
      <a class="button button-ghost button-small" href={`${appUrl}/signup`}>Start free <span aria-hidden="true">↗</span></a>
    </div>
    {columns.map(([heading, links]) => (
      <div class="footer-column">
        <h2>{heading}</h2>
        {links.map(([label, href]) => <a href={href}>{label}</a>)}
      </div>
    ))}
  </div>
  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} GroupWire. All rights reserved.</p>
    <p>WhatsApp, WordPress, and Facebook are trademarks of their respective owners. No official WhatsApp partnership is implied.</p>
  </div>
</footer>
